{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://security-audit.local/schemas/port-scan.schema.json",
  "title": "Port Scan Result",
  "description": "Schema for individual port scan results",
  "type": "object",
  "required": ["port", "protocol", "transport_protocol", "ip", "scan_time"],
  "properties": {
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "Port number"
    },
    "protocol": {
      "type": "string",
      "description": "Application layer protocol"
    },
    "transport_protocol": {
      "type": "string",
      "enum": ["TCP", "UDP"],
      "description": "Transport layer protocol"
    },
    "ip": {
      "type": "string",
      "format": "ipv4",
      "description": "Target IP address"
    },
    "scan_time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of scan"
    },
    "misconfigs": {
      "type": "array",
      "items": {"type": "object"},
      "default": []
    },
    "exposures": {
      "type": "array",
      "items": {"type": "object"},
      "default": []
    },
    "vulns": {
      "type": "array",
      "items": {"type": "object"},
      "default": []
    },
    "software": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "vendor": {"type": "string"},
          "product": {"type": "string"},
          "version": {"type": "string"},
          "cpe": {"type": "string"}
        }
      }
    },
    "operating_systems": {
      "type": "array",
      "items": {"type": "object"}
    },
    "threats": {
      "type": "array",
      "items": {"type": "object"},
      "default": []
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": {"type": "string"},
          "evidence": {"type": "array"}
        }
      }
    },
    "screenshots": {
      "type": "array",
      "default": []
    }
  }
}
